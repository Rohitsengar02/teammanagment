rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Rules for employers onboarding collection
    match /employers/{employerId} {
      // Allow anybody to register/create a new profile during onboarding
      allow create: if true;
      
      // Allow read/update if needed for authenticated or prototype sessions
      allow read, update, delete: if true;

      // Rules for employees subcollection
      match /employees/{employeeId} {
        allow read, write: if true;
      }
    }

    // Default catch-all rules for other prototype collections (leads, tasks, employees)
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
